{
	"name": "macos-system-optimizer",
	"version": "1.0.0",
	"description": "Electrobun desktop utility for real-time macOS health monitoring",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build && electrobun build",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.16.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"systeminformation": "^5.31.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^6.0.1",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.2.1",
		"postcss": "^8.5.8",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
