{
	"name": "macos-system-optimizer",
	"version": "1.0.0",
	"description": "Electrobun desktop utility for real-time macOS health monitoring",
	"scripts": {
		"renderer:build": "vite build",
		"start": "bun run renderer:build && electrobun dev",
		"dev": "bun run renderer:build && electrobun dev --watch",
		"start:hmr": "bun run renderer:build && ELECTROBUN_USE_HMR=1 electrobun dev",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start:hmr\"",
		"hmr": "vite --port 5173",
		"build": "bun run renderer:build && electrobun build",
		"build:canary": "bun run renderer:build && electrobun build --env=canary",
		"format": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write"
	},
	"dependencies": {
		"@radix-ui/react-progress": "^1.1.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-slot": "^1.2.4",
		"@tanstack/react-query": "^5.95.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"lucide-react": "^1.7.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"systeminformation": "^5.31.5",
		"tailwind-merge": "^3.5.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^5.2.0",
		"concurrently": "^9.2.1",
		"tailwindcss": "^4",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
